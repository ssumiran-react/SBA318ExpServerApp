<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NBA Teams List</title>

    <!-- Bootstrap CSS -->
    <link 
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" 
        rel="stylesheet"
    >
    <link rel="stylesheet" type="text" href="../stylessheet/styleTeams.css">
</head>

<body class="p-4">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="#">NBA</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Teams</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Standings</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Players</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container">
        <h3 class="mb-4">NBA Teams</h3>

        <div class="row g-4">

            <!-- Card 1 -->
            <div class="col-md-6">
                <div class="card data-card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        Western Teams
                    </div>
                    <div class="card-body p-0">
                        <table class="table mb-0  align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Team</th>
                                    <th>Division</th>
                                    <th>Players</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% for (const t of teams) { 
                                    if(t.conference == "Eastern") { %>
                                <tr>
                                    
                                    <td><%= t.id %></td>
                                    <td><%= t.name %></td>
                                    <td><%= t.division %></td>
                                    <td><%=  %></td>
                                </tr>
                                <% }} %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="col-md-6">
                <div class="card data-card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        Eastern Teams
                    </div>
                    <div class="card-body p-0">
                        <table class="table mb-0  ">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Team</th>
                                    <th>Division</th>
                                    <th>Players</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% for (const t of teams) { 
                                    if(t.conference == "Western") { %>
                                <tr> 
                                    <td><%= t.id %></td>
                                    <td><%= t.name %></td>
                                    <td><%= t.division %></td>
                                    <td><%=  %></td>
                                </tr>
                                <% }} %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>

</body>
</html>
