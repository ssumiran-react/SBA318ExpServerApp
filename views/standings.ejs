<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Players + CRUD Form</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        thead th {
            background-color: #0d6efd;
            color: white;
        }
        tbody tr:nth-child(even) {
            background-color: #f0f0f0;
        }
        .data-card {
            border-radius: 10px;
            overflow: hidden;
        }
    </style>
</head>

<body class="p-4">
<!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="#">NBA</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link active" href="http://localhost:3000/home">Home</a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link" href="http://localhost:3000/teams">Teams</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="http://localhost:3000/standings"">Standings</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="http://localhost:3000/players"">Players</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container-fluid">
        <div class="row g-4 justify-content-center ">

            <!-- PLAYERS TABLE (col-6) -->
            <div class="col-md-10">
                <div class="card data-card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        NBA Standings <%- new Date().getFullYear() %>
                    </div>
                    <div class="card-body p-0">
                        <table class="table mb-0  align-middle">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Team</th>  
                                    <th>conference</th>                                  
                                    <th>W</th>
                                    <th>L</th>
                                    <!-- <th>Year</th> -->
                                </tr>
                            </thead>
                            <tbody>
                                <% wlStandings.forEach( (s)=> { %>
                                <tr>
                                    <td><%= s.id %></td>
                                    <td><%= s.team %></td>
                                    <td><%= s.conference %></td>
                                    <td><%= s.win %></td>
                                    <td><%= s.lost %></td>
                                    <!-- <td><%= s.year %></td> -->                                    
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            

        </div>
    </div>
    <script>
        function submitForm(){
            console.log("clear");

        }
    </script>
</body>
</html>
 