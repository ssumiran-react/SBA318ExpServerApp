<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Players + CRUD Form</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        thead th {
            background-color: #0d6efd;
            color: white;
        }

        tbody tr:nth-child(even) {
            background-color: #f0f0f0;
        }

        .data-card {
            border-radius: 10px;
            overflow: hidden;
        }

        /* Make the row look like a link */
        tr.clickable {
            color: blue;
            text-decoration: underline;
            cursor: pointer;
        }

        /* Optional: hover effect */
        tr.clickable:hover {
            background-color: #f0f8ff;
        }
    </style>
</head>

<body class="p-4">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="#">NBA</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link active" href="http://localhost:3000/home">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="http://localhost:3000/teams">Teams</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="http://localhost:3000/standings">Standings</a>
                    </li>
                    <li class=" nav-item">
                            <a class="nav-link" href="http://localhost:3000/players">Players</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class=" container-fluid">
        <div class="row g-4">

            <!-- PLAYERS TABLE (col-6) -->
            <div class="col-md-8">
                <div class="card data-card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        Players List
                    </div>
                    <div class="card-body p-0">
                        <table class="table mb-0  align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Player</th>
                                    <th>Team</th>
                                    <th>Pos</th>
                                    <th>Ht</th>
                                    <th>Wt</th>
                                    <!-- <th>ID</th> -->
                                </tr>
                            </thead>
                            <tbody>
                                <% for (const p of teamPlayers) { %>
                                    <tr>
                                        <td>
                                            <%= p.number %>
                                        </td>
                                        <td onclick='fillPlayerForm(<%- JSON.stringify(p) %>)'
                                            style="color: blue; text-decoration: underline;">
                                            <%= p.firstName + " " + p.lastName %>
                                        </td>
                                        <td>
                                            <%= p.teamId %>
                                        </td>
                                        <td>
                                            <%= p.position %>
                                        </td>
                                        <td>
                                            <%= p.height %> ft
                                        </td>
                                        <td>
                                            <%= p.weight %> lbs
                                        </td>
                                        <!-- <td><%= p.id%></td> -->
                                    </tr>
                                    <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- CRUD FORM (col-4) -->
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        Modify Player Form
                    </div>
                    <div class="card-body">

                        <form id="myForm">
                            <div class="mb-3">
                                <label class="form-label">Id Number</label>
                                <input type="text" class="form-control" id="idNum" name="idNum"
                                    readonly>
                            </div>
                            <div class="d-flex gap-2">
                                <label class="form-label">Team</label>
                                <input type="text" class="form-control" id="teamId"
                                    name="teamId">
                                <label class="form-label">Number</label>
                                <input type="number" class="form-control" id="number"
                                    name="number">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" id="firstName"
                                    name="firstName">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" id="lastName"
                                    name="lastName">
                            </div>
                            <div class="d-flex gap-2">
                                <label class="form-label">Height</label>
                                <input type="number" class="form-control" id="height"
                                    name="height">

                                <label class="form-label">Weight</label>
                                <input type="number" class="form-control" id="weight"
                                    name="weight">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Position</label>
                                <input type="text" class="form-control" id="position"
                                    name="position">
                            </div>
                            <div class="d-flex gap-2">
                                <button type="button" id="btnCreate"
                                    class="btn btn-success w-100">Create</button>
                                <button type="button"  id="btnUpdate"
                                    class="btn btn-warning w-100">Update</button>
                            </div>

                            <div class="d-flex gap-2 mt-2">
                                <button type="button" id="btnDelete"
                                    class="btn btn-danger w-100">Delete</button>
                                <button type="reset" id="btnClear"
                                    class="btn btn-secondary w-100">Clear</button>
                            </div>

                        </form>

                    </div>
                </div>
            </div>

        </div>
            </div>
<script>
    function fillPlayerForm(pInfo) {
        document.getElementById("idNum").value = pInfo.id;
        document.getElementById("teamId").value = pInfo.teamId;
        document.getElementById("number").value = pInfo.number;
        document.getElementById("firstName").value = pInfo.firstName;
        document.getElementById("lastName").value = pInfo.lastName;
        document.getElementById("height").value = pInfo.height;
        document.getElementById("weight").value = pInfo.weight;
        document.getElementById("position").value = pInfo.position;
    }

    document.getElementById("btnCreate").addEventListener('click', async () => {
        const formData = new FormData(document.getElementById('myForm'));
        const data = Object.fromEntries(formData.entries());
        //console.log("btnCreate",typeof data.idNum);
        if (firstName && lastName && teamId) {
            const res = await fetch('http://localhost:3000/players/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            
            if(await res.status == 200){ 
                document.getElementById("btnClear").click();
                alert("Player is successfully added.");
            }
            if(await res.status == 400){
                alert("Player information is not completed.");
            }
        }else{
            alert("Player information is required.");
        }
    })

    document.getElementById("btnUpdate").addEventListener('click', async () => {
        const formData = new FormData(document.getElementById('myForm'));
        const data = Object.fromEntries(formData.entries());
        console.log( data.height," btnUpdate ",data.height);
        if(data.idNum != ""){
            const res = await fetch('http://localhost:3000/players/', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            
            if(await res.status == 200){
                document.getElementById("btnClear").click();
                alert("Player is successfully Updated.");
            }
            if(await res.status == 404){
                alert("Player information is not completed.");
            }
        }else{
            alert("Player information is required.");
        }
    })

    document.getElementById("btnDelete").addEventListener('click', async () => {
        const formData = new FormData(document.getElementById('myForm'));
        const data = Object.fromEntries(formData.entries());
        //console.log("inDelete",typeof data.idNum);
        if(data.idNum != ""){
            const res = await fetch('http://localhost:3000/players/', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            
            if(await res.status == 200){
                document.getElementById("btnClear").click();
                alert("Player is deleted.");
            }
            if(await res.status == 404){
                alert("Player does not exist.");
            }
        }else{
            alert("Player information is required.");
        }
    })

</script>
</body>

</html>